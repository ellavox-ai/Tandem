# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Redis (BullMQ) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Claude API ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI (Realtime Voice Interviews) ──────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Jira ────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_DEFAULT_PROJECT=SCRUM
# Custom field ID for story points (find via Jira Admin > Issues > Custom Fields)
# Common values: customfield_10016, story_points — leave blank to skip
# JIRA_STORY_POINTS_FIELD=customfield_10016

# ─── Slack Notifications ─────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Webhook Auth ────────────────────────────────────────────────────────────
# Static secret for authenticating incoming webhooks.
# Callers must send this as x-webhook-secret header or Bearer token.
WEBHOOK_SECRET=your-webhook-secret-here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info

# ─── n8n Integration ─────────────────────────────────────────────────────────
# n8n watches Google Drive and forwards transcripts via POST /api/webhooks/n8n.
# No extra env vars needed — uses WEBHOOK_SECRET above for auth.
# See docs/n8n-google-drive-setup.md for full setup instructions.

# ─── Google Meet Provider (Phase 1) ─────────────────────────────────────────
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/meet-transcripts

# ─── Zoom Provider (Phase 3) ────────────────────────────────────────────────
# ZOOM_CLIENT_ID=...
# ZOOM_CLIENT_SECRET=...
# ZOOM_ACCOUNT_ID=...
# ZOOM_WEBHOOK_VERIFICATION_TOKEN=...

# ─── MS Teams Provider (Phase 3) ────────────────────────────────────────────
# AZURE_TENANT_ID=...
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...
